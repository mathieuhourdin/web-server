{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["user", "hlp", "trace", "landmark"]
        },
        "feedback_mode": {
          "type": "string",
          "enum": [
            "reflection",
            "guidance",
            "playful",
            "resource",
            "technical",
            "recognition",
            "support"
          ]
        },
        "tone": {
          "type": "string",
          "enum": ["warm", "light", "serious", "playful", "direct"]
        },
        "subject": {
          "type": "string"
        }
      },
      "required": ["scope", "feedback_mode", "tone", "subject"]
    }
  },
  "required": ["title", "content", "metadata"]
}
